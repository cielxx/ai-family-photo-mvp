.home-page {
  background:
    radial-gradient(circle at 20% 0%, rgba(255, 255, 255, 0.78), transparent 34%),
    linear-gradient(180deg, #fbf6ec 0%, #f7efe4 100%);
  min-height: 100vh;
  padding: 0 40rpx 38rpx;
}

.custom-nav {
  align-items: flex-end;
  box-sizing: border-box;
  display: flex;
  height: 158rpx;
  justify-content: center;
  padding-bottom: 26rpx;
}

.nav-title {
  color: #111111;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1;
}

.topbar {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 26rpx;
}

.brand {
  color: #4f4a3f;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 32rpx;
  font-weight: 700;
}

.privacy-link {
  color: #24221e;
  font-size: 24rpx;
}

.hero-title {
  color: #4f4a3f;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 50rpx;
  font-weight: 700;
  line-height: 1.24;
  margin-bottom: 18rpx;
}

.hero-copy {
  color: #24221e;
  font-size: 22rpx;
  line-height: 1.36;
  margin-bottom: 20rpx;
}

.trust-row {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(3, 1fr);
  margin-bottom: 18rpx;
}

.trust-pill {
  align-items: center;
  border: 1rpx solid #d9cdb4;
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #666056;
  display: flex;
  font-size: 18rpx;
  gap: 6rpx;
  height: 56rpx;
  justify-content: center;
  white-space: nowrap;
}

.trust-icon {
  align-items: center;
  background: #746f5e;
  border-radius: 50%;
  color: #fffaf2;
  display: flex;
  flex-shrink: 0;
  font-size: 16rpx;
  height: 28rpx;
  justify-content: center;
  position: relative;
  width: 28rpx;
}

.icon-user-head {
  background: #fffaf2;
  border-radius: 50%;
  height: 8rpx;
  position: absolute;
  top: 6rpx;
  width: 8rpx;
}

.icon-user-body {
  border-bottom: 8rpx solid #fffaf2;
  border-left: 6rpx solid transparent;
  border-right: 6rpx solid transparent;
  height: 0;
  position: absolute;
  top: 15rpx;
  width: 8rpx;
}

.icon-lock-shackle {
  border: 2rpx solid #fffaf2;
  border-bottom: 0;
  border-radius: 8rpx 8rpx 0 0;
  height: 8rpx;
  position: absolute;
  top: 6rpx;
  width: 12rpx;
}

.icon-lock-body {
  background: #fffaf2;
  border-radius: 3rpx;
  height: 10rpx;
  position: absolute;
  top: 13rpx;
  width: 16rpx;
}

.icon-slider-line {
  background: #fffaf2;
  border-radius: 999rpx;
  height: 2rpx;
  position: absolute;
  width: 16rpx;
}

.icon-slider-line::after {
  background: #746f5e;
  border: 2rpx solid #fffaf2;
  border-radius: 50%;
  content: "";
  height: 4rpx;
  position: absolute;
  top: -3rpx;
  width: 4rpx;
}

.icon-slider-line.top {
  top: 8rpx;
}

.icon-slider-line.top::after {
  left: 2rpx;
}

.icon-slider-line.middle {
  top: 14rpx;
}

.icon-slider-line.middle::after {
  right: 2rpx;
}

.icon-slider-line.bottom {
  top: 20rpx;
}

.icon-slider-line.bottom::after {
  left: 6rpx;
}

.hero-preview {
  border-radius: 18rpx;
  box-shadow: 0 10rpx 22rpx rgba(60, 48, 35, 0.16);
  height: 356rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  position: relative;
}

.hero-image {
  display: block;
  height: 100%;
  position: absolute;
  top: 0;
  width: 50%;
}

.hero-before {
  left: 0;
}

.hero-after {
  right: 0;
}

.hero-preview::after {
  background: rgba(255, 255, 255, 0.72);
  content: "";
  height: 100%;
  left: 50%;
  position: absolute;
  top: 0;
  width: 2rpx;
  z-index: 1;
}

.hero-label {
  border-radius: 12rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 400;
  left: 28rpx;
  padding: 6rpx 16rpx;
  position: absolute;
  top: 28rpx;
}

.hero-label.before {
  background: #3f3e3a;
}

.hero-label.after {
  background: #8e9369;
  left: auto;
  right: 28rpx;
}

.service-heading {
  color: #4a4f3f;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin: 20rpx 0 18rpx;
  text-align: center;
}

.home-services {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.home-service-card {
  align-items: center;
  background: #fffbf5;
  border: 1rpx solid #d9cdb4;
  border-radius: 16rpx;
  box-sizing: border-box;
  display: grid;
  gap: 16rpx;
  grid-template-columns: 96rpx 42rpx 1fr 122rpx;
  min-height: 130rpx;
  padding: 10rpx 16rpx 10rpx 12rpx;
}

.service-thumb {
  border-radius: 12rpx;
  height: 106rpx;
  width: 96rpx;
}

.service-icon {
  align-items: center;
  background: #f4eadb;
  border-radius: 50%;
  color: #746f5e;
  display: flex;
  font-size: 20rpx;
  font-weight: 700;
  height: 42rpx;
  justify-content: center;
  position: relative;
  width: 42rpx;
}

.palette-dot,
.magic-stick,
.magic-spark,
.profile-head,
.profile-body {
  display: none;
}

.service-icon-palette {
  border-radius: 50% 50% 46% 52%;
}

.service-icon-palette::before {
  background: transparent;
  border: 3rpx solid #746f5e;
  border-radius: 50%;
  content: "";
  height: 22rpx;
  position: absolute;
  width: 24rpx;
}

.service-icon-palette::after {
  background: #f4eadb;
  border-radius: 50%;
  content: "";
  height: 6rpx;
  position: absolute;
  right: 9rpx;
  top: 23rpx;
  width: 6rpx;
}

.service-icon-palette .palette-dot {
  background: #746f5e;
  border-radius: 50%;
  display: block;
  height: 4rpx;
  position: absolute;
  width: 4rpx;
  z-index: 1;
}

.palette-dot.one {
  left: 14rpx;
  top: 14rpx;
}

.palette-dot.two {
  left: 22rpx;
  top: 13rpx;
}

.palette-dot.three {
  left: 16rpx;
  top: 22rpx;
}

.service-icon-magic .magic-stick {
  background: #746f5e;
  border-radius: 999rpx;
  display: block;
  height: 4rpx;
  position: absolute;
  transform: rotate(-42deg);
  width: 24rpx;
}

.service-icon-magic .magic-stick::before {
  background: #746f5e;
  border-radius: 2rpx;
  content: "";
  height: 9rpx;
  left: 3rpx;
  position: absolute;
  top: -2rpx;
  width: 3rpx;
}

.service-icon-magic .magic-spark {
  color: #746f5e;
  display: block;
  font-size: 16rpx;
  line-height: 1;
  position: absolute;
}

.service-icon-magic .magic-spark::before {
  content: "✦";
}

.magic-spark.one {
  right: 9rpx;
  top: 8rpx;
}

.magic-spark.two {
  bottom: 8rpx;
  font-size: 12rpx;
  left: 9rpx;
}

.service-icon-profile .profile-head {
  background: #746f5e;
  border-radius: 50%;
  display: block;
  height: 12rpx;
  position: absolute;
  top: 10rpx;
  width: 12rpx;
}

.service-icon-profile .profile-body {
  background: #746f5e;
  border-radius: 12rpx 12rpx 8rpx 8rpx;
  bottom: 9rpx;
  display: block;
  height: 12rpx;
  position: absolute;
  width: 22rpx;
}

.service-text {
  min-width: 0;
}

.service-name {
  color: #4a4f3f;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.25;
  margin-bottom: 8rpx;
}

.service-desc {
  color: #666056;
  font-size: 18rpx;
  line-height: 1.35;
}

.service-cta {
  align-items: center;
  background: #fdfaf6;
  border: 1rpx solid #9d9f80;
  border-radius: 16rpx;
  box-sizing: border-box;
  color: #5b6631;
  display: flex;
  font-size: 20rpx;
  gap: 6rpx;
  height: 48rpx;
  justify-content: center;
  padding: 0 12rpx;
  white-space: nowrap;
}

.service-arrow {
  font-size: 24rpx;
  line-height: 1;
  transform: translateY(-1rpx);
}

.steps-card {
  background: #fffbf5;
  border: 1rpx solid #d9cdb4;
  border-radius: 16rpx;
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
}

.steps-title {
  color: #4a4f3f;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: 3rpx;
  margin-bottom: 16rpx;
  text-align: center;
}

.steps-row {
  align-items: flex-start;
  display: grid;
  column-gap: 0;
  grid-template-columns: minmax(0, 1fr) 46rpx minmax(0, 1fr) 46rpx minmax(0, 1fr);
}

.step-item {
  align-items: center;
  display: flex;
  gap: 8rpx;
  justify-content: center;
  min-width: 0;
}

.step-icon {
  align-items: center;
  background: #efe4d4;
  border-radius: 12rpx;
  color: #4a4f3f;
  display: flex;
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 700;
  height: 44rpx;
  justify-content: center;
  position: relative;
  width: 44rpx;
}

.upload-tray {
  border: 3rpx solid #746f5e;
  border-top: 0;
  border-radius: 0 0 6rpx 6rpx;
  bottom: 12rpx;
  height: 8rpx;
  position: absolute;
  width: 20rpx;
}

.upload-arrow {
  background: #746f5e;
  border-radius: 999rpx;
  height: 18rpx;
  position: absolute;
  top: 10rpx;
  width: 3rpx;
}

.upload-arrow::before {
  border-left: 7rpx solid transparent;
  border-right: 7rpx solid transparent;
  border-bottom: 8rpx solid #746f5e;
  content: "";
  left: -6rpx;
  position: absolute;
  top: -3rpx;
}

.step-spark {
  color: #746f5e;
  line-height: 1;
  position: absolute;
}

.step-spark::before {
  content: "✦";
}

.step-spark.main {
  font-size: 24rpx;
}

.step-spark.small {
  font-size: 13rpx;
}

.step-spark.top {
  right: 9rpx;
  top: 8rpx;
}

.step-spark.bottom {
  bottom: 7rpx;
  left: 9rpx;
}

.adjust-line {
  background: #746f5e;
  border-radius: 999rpx;
  height: 3rpx;
  position: absolute;
  width: 24rpx;
}

.adjust-line::after {
  background: #efe4d4;
  border: 3rpx solid #746f5e;
  border-radius: 50%;
  content: "";
  height: 5rpx;
  position: absolute;
  top: -4rpx;
  width: 5rpx;
}

.adjust-line.top {
  top: 13rpx;
}

.adjust-line.top::after {
  left: 4rpx;
}

.adjust-line.middle {
  top: 21rpx;
}

.adjust-line.middle::after {
  right: 4rpx;
}

.adjust-line.bottom {
  top: 29rpx;
}

.adjust-line.bottom::after {
  left: 10rpx;
}

.step-name {
  color: #4a4f3f;
  font-size: 17rpx;
  font-weight: 700;
  line-height: 1.25;
  white-space: nowrap;
}

.step-desc {
  color: #666056;
  font-size: 12rpx;
  line-height: 1.3;
  margin-top: 4rpx;
  white-space: nowrap;
}

.step-arrow {
  background: #d9cdb4;
  align-self: flex-start;
  height: 2rpx;
  justify-self: center;
  margin-top: 21rpx;
  position: relative;
  width: 28rpx;
}

.step-arrow::after {
  border-right: 2rpx solid #d9cdb4;
  border-top: 2rpx solid #d9cdb4;
  content: "";
  height: 8rpx;
  position: absolute;
  right: 0;
  top: -3rpx;
  transform: rotate(45deg);
  width: 8rpx;
}
