.home-page {
  display: flex;
  flex-direction: column;
}

.preview-pair {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1fr 1fr;
  margin: 18rpx 0 10rpx;
}

.preview-item {
  min-width: 0;
}

.preview-image {
  border-radius: 18rpx;
  height: 360rpx;
  width: 100%;
}

.preview-label {
  color: #6b7280;
  font-size: 24rpx;
  margin-top: 12rpx;
  text-align: center;
}

.service-list {
  background: rgba(255, 253, 248, 0.72);
  border-radius: 14rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding: 22rpx 24rpx;
}

.service-line {
  align-items: center;
  color: #2f4f4d;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  gap: 14rpx;
}

.dot {
  background: #5b9a96;
  border-radius: 50%;
  flex-shrink: 0;
  height: 12rpx;
  width: 12rpx;
}
