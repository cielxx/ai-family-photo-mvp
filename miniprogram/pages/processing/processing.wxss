.processing-page {
  background:
    radial-gradient(circle at 18% 0%, rgba(255, 255, 255, 0.78), transparent 34%),
    linear-gradient(180deg, #fbf6ec 0%, #f7efe4 100%);
  box-sizing: border-box;
  min-height: 100vh;
  padding: 92rpx 42rpx 38rpx;
}

.process-nav {
  align-items: center;
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.back-button {
  background: #fcf7f4;
  border: 1rpx solid #ebe0d4;
  border-radius: 20rpx;
  box-sizing: border-box;
  height: 56rpx;
  position: relative;
  width: 56rpx;
}

.back-button::before {
  border-left: 4rpx solid #5c574e;
  border-top: 4rpx solid #5c574e;
  content: "";
  height: 18rpx;
  left: 22rpx;
  position: absolute;
  top: 17rpx;
  transform: rotate(-45deg);
  width: 18rpx;
}

.service-chip {
  align-items: center;
  background: #f9f4ec;
  border: 1rpx solid #e8ddce;
  border-radius: 20rpx;
  color: #666056;
  display: flex;
  font-size: 22rpx;
  height: 48rpx;
  padding: 0 18rpx;
}

.service-chip-name {
  color: #3f4c20;
}

.process-title {
  color: #33441c;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 18rpx;
}

.process-copy {
  color: #666056;
  font-size: 22rpx;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.upload-summary-card,
.progress-card,
.wait-card {
  background: #fdf9f4;
  border: 1rpx solid #ece0d1;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.upload-summary-card {
  display: grid;
  gap: 20rpx;
  grid-template-columns: 336rpx 1fr;
  margin-bottom: 24rpx;
  min-height: 248rpx;
  padding: 22rpx 18rpx;
}

.summary-image {
  border-radius: 14rpx;
  display: block;
  height: 186rpx;
  width: 336rpx;
}

.summary-info {
  min-width: 0;
  padding-top: 8rpx;
}

.summary-status {
  align-items: center;
  background: #f0efe6;
  border-radius: 16rpx;
  color: #5b6631;
  display: inline-flex;
  font-size: 20rpx;
  gap: 4rpx;
  height: 42rpx;
  margin-bottom: 14rpx;
  padding: 0 12rpx;
}

.summary-check {
  background: #eef0e5;
  border-radius: 50%;
  height: 28rpx;
  position: relative;
  width: 28rpx;
}

.summary-check::after {
  border-bottom: 3rpx solid #5b6631;
  border-left: 3rpx solid #5b6631;
  content: "";
  height: 7rpx;
  left: 7rpx;
  position: absolute;
  top: 7rpx;
  transform: rotate(-45deg);
  width: 13rpx;
}

.summary-name {
  color: #4a4f3f;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 1.4;
  margin-bottom: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.summary-meta {
  color: #666056;
  font-size: 20rpx;
  line-height: 1.45;
}

.progress-card {
  margin-bottom: 24rpx;
  min-height: 352rpx;
  padding: 24rpx 34rpx 26rpx;
}

.progress-art {
  height: 106rpx;
  margin: 0 auto 12rpx;
  position: relative;
  width: 222rpx;
}

.progress-photo {
  background:
    linear-gradient(135deg, rgba(142, 148, 107, 0.2), rgba(142, 148, 107, 0.05)),
    #f9f4ec;
  border: 3rpx solid #d9cdb4;
  border-radius: 16rpx;
  height: 86rpx;
  left: 34rpx;
  position: absolute;
  top: 14rpx;
  transform: rotate(-4deg);
  width: 148rpx;
}

.progress-photo::before {
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 28rpx solid #8e946b;
  bottom: 12rpx;
  content: "";
  left: 24rpx;
  opacity: 0.8;
  position: absolute;
}

.progress-photo::after {
  background: #8e946b;
  border-radius: 50%;
  content: "";
  height: 11rpx;
  position: absolute;
  right: 22rpx;
  top: 18rpx;
  width: 11rpx;
}

.progress-spark {
  color: #8e946b;
  position: absolute;
}

.progress-spark::before {
  content: "✦";
}

.progress-spark.one {
  font-size: 30rpx;
  right: 20rpx;
  top: 8rpx;
}

.progress-spark.two {
  bottom: 12rpx;
  font-size: 22rpx;
  left: 8rpx;
}

.progress-spark.three {
  bottom: 20rpx;
  font-size: 18rpx;
  right: 34rpx;
}

.progress-title {
  color: #33441c;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 28rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
}

.progress-list {
  padding: 0 18rpx;
}

.progress-row {
  align-items: center;
  display: grid;
  grid-template-columns: 48rpx 1fr auto;
  min-height: 70rpx;
  position: relative;
}

.progress-marker {
  border-radius: 50%;
  height: 26rpx;
  justify-self: center;
  position: relative;
  width: 26rpx;
  z-index: 1;
}

.progress-marker.done {
  background: #eef0e5;
}

.progress-marker.done::after {
  border-bottom: 3rpx solid #5b6631;
  border-left: 3rpx solid #5b6631;
  content: "";
  height: 6rpx;
  left: 7rpx;
  position: absolute;
  top: 7rpx;
  transform: rotate(-45deg);
  width: 12rpx;
}

.progress-marker.active {
  animation: pulse 1.1s ease-in-out infinite;
  background: #8e946b;
  height: 18rpx;
  width: 18rpx;
}

.progress-marker.pending {
  background: #d9cdb4;
  height: 18rpx;
  opacity: 0.9;
  width: 18rpx;
}

.progress-line {
  background: #d9cdb4;
  height: 36rpx;
  left: 23rpx;
  position: absolute;
  top: 45rpx;
  width: 2rpx;
}

.progress-name {
  color: #5f6258;
  font-size: 24rpx;
  font-weight: 400;
}

.progress-state {
  color: #666056;
  font-size: 22rpx;
  font-weight: 400;
}

.progress-state.done {
  color: #667246;
}

.progress-state.active {
  color: #667246;
  font-weight: 400;
}

.wait-card {
  align-items: center;
  display: grid;
  gap: 16rpx;
  grid-template-columns: 72rpx 1fr;
  margin-bottom: 24rpx;
  min-height: 116rpx;
  padding: 19rpx 20rpx;
}

.timer-icon {
  border: 5rpx solid #8e946b;
  border-radius: 50%;
  height: 52rpx;
  position: relative;
  width: 52rpx;
}

.timer-icon::before {
  background: #8e946b;
  border-radius: 999rpx;
  content: "";
  height: 18rpx;
  left: 24rpx;
  position: absolute;
  top: 11rpx;
  width: 4rpx;
}

.timer-icon::after {
  background: #8e946b;
  border-radius: 999rpx;
  content: "";
  height: 4rpx;
  left: 24rpx;
  position: absolute;
  top: 26rpx;
  transform: rotate(35deg);
  transform-origin: left center;
  width: 16rpx;
}

.wait-title {
  color: #5f6258;
  font-size: 24rpx;
  font-weight: 400;
  line-height: 1.4;
}

.wait-desc {
  color: #666056;
  font-size: 20rpx;
  line-height: 1.5;
  margin-top: 4rpx;
}

.process-actions {
  text-align: center;
}

.primary-process-action,
.secondary-process-action {
  align-items: center;
  border-radius: 16rpx;
  box-sizing: border-box;
  display: flex;
  font-size: 26rpx;
  font-weight: 400;
  height: 82rpx;
  justify-content: center;
  margin: 0 auto;
  width: 100%;
}

.primary-process-action {
  background: #788053;
  color: #ffffff;
  font-weight: 400;
  letter-spacing: 3rpx;
  margin-bottom: 18rpx;
}

.secondary-process-action {
  background: #fdf9f4;
  border: 1rpx solid #d9cdb4;
  color: #666056;
  font-weight: 400;
  height: 62rpx;
  letter-spacing: 2rpx;
  margin-bottom: 10rpx;
}

.cancel-action {
  color: #8b7d6a;
  font-size: 22rpx;
  line-height: 42rpx;
}

@keyframes pulse {
  0% {
    opacity: 0.5;
    transform: scale(0.92);
  }

  50% {
    opacity: 1;
    transform: scale(1.08);
  }

  100% {
    opacity: 0.5;
    transform: scale(0.92);
  }
}
