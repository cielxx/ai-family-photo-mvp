.result-page {
  background:
    radial-gradient(circle at 18% 0%, rgba(255, 255, 255, 0.78), transparent 34%),
    linear-gradient(180deg, #fbf6ec 0%, #f7efe4 100%);
  box-sizing: border-box;
  min-height: 100vh;
  padding: 88rpx 42rpx 38rpx;
}

.result-nav {
  align-items: center;
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.back-button {
  background: #fcf7f4;
  border: 1rpx solid #ebe0d4;
  border-radius: 20rpx;
  box-sizing: border-box;
  height: 56rpx;
  position: relative;
  width: 56rpx;
}

.back-button::before {
  border-left: 4rpx solid #5c574e;
  border-top: 4rpx solid #5c574e;
  content: "";
  height: 18rpx;
  left: 22rpx;
  position: absolute;
  top: 17rpx;
  transform: rotate(-45deg);
  width: 18rpx;
}

.service-chip {
  align-items: center;
  background: #f9f4ec;
  border: 1rpx solid #e8ddce;
  border-radius: 20rpx;
  color: #666056;
  display: flex;
  font-size: 22rpx;
  height: 48rpx;
  padding: 0 18rpx;
}

.service-chip-name {
  color: #3f4c20;
}

.result-title {
  color: #33441c;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 48rpx;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 18rpx;
}

.result-copy {
  color: #666056;
  font-size: 22rpx;
  line-height: 1.6;
  margin-bottom: 32rpx;
}

.compare-photo-card,
.explain-card,
.feedback-card,
.adjusted-summary-card,
.adjusted-feedback-card,
.adjusted-note-card {
  background: #fdf9f4;
  border: 1rpx solid #ece0d1;
  border-radius: 20rpx;
  box-sizing: border-box;
}

.compare-photo-card {
  margin-bottom: 36rpx;
  padding: 16rpx 18rpx;
}

.split-compare {
  border-radius: 18rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  height: 420rpx;
  overflow: hidden;
  position: relative;
}

.result-page.adjusted .split-compare {
  height: 392rpx;
}

.split-image {
  min-width: 0;
  position: relative;
}

.split-image image {
  display: block;
  height: 100%;
  width: 100%;
}

.split-image.left image {
  filter: sepia(0.32) saturate(0.65);
}

.image-badge {
  border-radius: 16rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 400;
  height: 52rpx;
  left: 20rpx;
  line-height: 52rpx;
  padding: 0 20rpx;
  position: absolute;
  top: 20rpx;
}

.image-badge.dark {
  background: rgba(62, 61, 54, 0.86);
}

.image-badge.green {
  background: rgba(122, 134, 80, 0.92);
  left: auto;
  right: 20rpx;
}

.compare-divider {
  background: rgba(255, 255, 255, 0.92);
  height: 100%;
  left: 50%;
  position: absolute;
  top: 0;
  width: 3rpx;
}

.compare-handle {
  align-items: center;
  background: rgba(122, 134, 80, 0.58);
  border: 2rpx solid rgba(255, 255, 255, 0.76);
  border-radius: 50%;
  display: flex;
  height: 42rpx;
  justify-content: center;
  left: 50%;
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 42rpx;
}

.compare-handle::before {
  border: 3rpx solid rgba(255, 255, 255, 0.84);
  border-radius: 3rpx;
  box-sizing: border-box;
  content: "";
  height: 10rpx;
  left: 50%;
  position: absolute;
  top: 50%;
  transform: translate(-50%, -50%) rotate(45deg);
  width: 10rpx;
}

.paper-corner {
  border-bottom: 72rpx solid #eadabd;
  border-left: 72rpx solid transparent;
  bottom: 0;
  filter: drop-shadow(-4rpx -4rpx 8rpx rgba(64, 48, 30, 0.14));
  position: absolute;
  right: 0;
}

.explain-card {
  margin-bottom: 36rpx;
  min-height: 332rpx;
  padding: 36rpx 34rpx 36rpx;
  position: relative;
}

.card-heading {
  align-items: center;
  color: #2f4721;
  display: grid;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 30rpx;
  font-weight: 500;
  gap: 14rpx;
  grid-template-columns: 26rpx auto 1fr;
  margin-bottom: 24rpx;
}

.heading-icon {
  position: relative;
}

.heading-icon.lines,
.heading-icon.chat,
.heading-icon.target {
  height: 24rpx;
  width: 24rpx;
}

.heading-icon.lines::before,
.heading-icon.lines::after {
  background: #7a8650;
  border-radius: 4rpx;
  content: "";
  height: 24rpx;
  position: absolute;
  width: 5rpx;
}

.heading-icon.lines::after {
  left: 12rpx;
}

.heading-rule {
  border-top: 1rpx dashed #dccfbd;
  height: 1rpx;
}

.explain-list,
.focus-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.explain-row,
.focus-row {
  align-items: center;
  color: #666056;
  display: grid;
  font-size: 24rpx;
  gap: 18rpx;
  grid-template-columns: 34rpx 1fr;
  line-height: 1.55;
}

.check-dot {
  background: #eef0e5;
  border-radius: 50%;
  height: 30rpx;
  position: relative;
  width: 30rpx;
}

.check-dot::after {
  border-bottom: 3rpx solid #667246;
  border-left: 3rpx solid #667246;
  content: "";
  height: 7rpx;
  left: 8rpx;
  position: absolute;
  top: 8rpx;
  transform: rotate(-45deg);
  width: 13rpx;
}

.check-dot.small {
  height: 28rpx;
  width: 28rpx;
}

.check-dot.small::after {
  border-width: 3rpx;
  height: 7rpx;
  left: 7rpx;
  top: 7rpx;
  width: 12rpx;
}

.mini-photo-card {
  background: linear-gradient(135deg, #ece5d8, #faf6ef);
  border: 10rpx solid #fffdf8;
  border-radius: 8rpx;
  bottom: 56rpx;
  box-shadow: 0 10rpx 24rpx rgba(75, 59, 38, 0.12);
  height: 74rpx;
  position: absolute;
  right: 46rpx;
  transform: rotate(2deg);
  width: 74rpx;
}

.feedback-card {
  align-items: center;
  display: grid;
  gap: 22rpx;
  grid-template-columns: 74rpx 1fr;
  margin-bottom: 36rpx;
  padding: 28rpx 30rpx;
}

.heart-bubble {
  background: #ead9ae;
  border: 4rpx solid #f5e9cd;
  border-radius: 50%;
  height: 58rpx;
  position: relative;
  width: 58rpx;
}

.heart-bubble::after {
  color: #7a8650;
  content: "♡";
  font-size: 34rpx;
  left: 13rpx;
  position: absolute;
  top: 8rpx;
}

.feedback-title {
  color: #34451d;
  font-size: 26rpx;
  font-weight: 400;
  line-height: 1.4;
}

.feedback-desc {
  color: #7a746b;
  font-size: 22rpx;
  line-height: 1.45;
}

.result-actions {
  align-items: center;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  width: 100%;
}

.primary-result-action,
.outline-result-action {
  align-items: center;
  border-radius: 999rpx;
  box-sizing: border-box;
  display: flex;
  font-size: 28rpx;
  font-weight: 400;
  gap: 16rpx;
  height: 80rpx;
  justify-content: center;
  letter-spacing: 3rpx;
  line-height: 1;
  margin: 0;
  padding: 0;
  width: 100%;
}

.primary-result-action {
  background: #6f7d4a;
  color: #ffffff;
}

.outline-result-action {
  background: rgba(255, 252, 247, 0.5);
  border: 1rpx solid #cfc5b8;
  color: #74746e;
  font-size: 26rpx;
  height: 68rpx;
  letter-spacing: 2rpx;
}

.text-action {
  color: #8a8780;
  font-size: 26rpx;
  line-height: 60rpx;
  text-align: center;
  text-decoration: underline;
}

.button-check,
.button-sliders,
.button-download {
  height: 32rpx;
  position: relative;
  width: 32rpx;
}

.button-check {
  border: 3rpx solid currentColor;
  border-radius: 50%;
}

.button-check::after {
  border-bottom: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  content: "";
  height: 8rpx;
  left: 8rpx;
  position: absolute;
  top: 8rpx;
  transform: rotate(-45deg);
  width: 14rpx;
}

.button-sliders::before,
.button-sliders::after {
  border-top: 3rpx solid currentColor;
  content: "";
  left: 2rpx;
  position: absolute;
  width: 28rpx;
}

.button-sliders::before {
  top: 9rpx;
}

.button-sliders::after {
  top: 22rpx;
}

.button-download::before {
  border-bottom: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  content: "";
  height: 14rpx;
  left: 10rpx;
  position: absolute;
  top: 4rpx;
  transform: rotate(-45deg);
  width: 14rpx;
}

.button-download::after {
  border-bottom: 3rpx solid currentColor;
  bottom: 4rpx;
  content: "";
  left: 4rpx;
  position: absolute;
  width: 24rpx;
}

.adjusted-summary-card {
  margin-bottom: 28rpx;
  padding: 34rpx 34rpx;
}

.adjusted-feedback-card {
  margin-bottom: 28rpx;
  padding: 30rpx 34rpx 32rpx;
}

.adjusted-section-title {
  color: #33441c;
  font-family: Georgia, "Times New Roman", serif;
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 24rpx;
}

.feedback-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx 36rpx;
}

.feedback-tag {
  align-items: center;
  border: 1rpx solid #9ca57a;
  border-radius: 18rpx;
  color: #5f6940;
  display: inline-flex;
  font-size: 24rpx;
  height: 52rpx;
  padding: 0 22rpx;
}

.tag-dot {
  background: #7a8650;
  border-radius: 50%;
  height: 22rpx;
  margin-right: 10rpx;
  position: relative;
  width: 22rpx;
}

.tag-dot::after {
  border-bottom: 3rpx solid #ffffff;
  border-left: 3rpx solid #ffffff;
  content: "";
  height: 5rpx;
  left: 5rpx;
  position: absolute;
  top: 6rpx;
  transform: rotate(-45deg);
  width: 10rpx;
}

.adjusted-focus-list {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
}

.adjusted-focus-row {
  align-items: center;
  color: #666056;
  display: grid;
  font-size: 24rpx;
  gap: 18rpx;
  grid-template-columns: 34rpx 1fr;
  line-height: 1.55;
}

.adjusted-note-card {
  align-items: center;
  display: grid;
  gap: 24rpx;
  grid-template-columns: 72rpx 1fr;
  margin-bottom: 32rpx;
  min-height: 96rpx;
  padding: 18rpx 28rpx;
}

.note-icon {
  background: #fffdf8;
  border: 2rpx solid #d7bd7f;
  border-radius: 8rpx;
  box-shadow: 0 8rpx 14rpx rgba(80, 56, 26, 0.12);
  height: 54rpx;
  position: relative;
  transform: rotate(-6deg);
  width: 46rpx;
}

.note-icon::before {
  background: #d4a24d;
  border-radius: 50%;
  content: "";
  height: 12rpx;
  left: 17rpx;
  position: absolute;
  top: -8rpx;
  width: 12rpx;
}

.note-icon::after {
  color: #7a8650;
  content: "♡";
  font-size: 24rpx;
  left: 10rpx;
  position: absolute;
  top: 13rpx;
}

.adjusted-note-card view {
  color: #5c574e;
  font-size: 23rpx;
  line-height: 1.5;
}

.adjusted-note-card .note-desc {
  color: #666056;
}

.result-page.adjusted .card-heading {
  font-weight: 400;
  margin-bottom: 28rpx;
}

.two-actions {
  display: grid;
  gap: 18rpx;
  grid-template-columns: 1fr 1fr;
  width: 100%;
}

.two-actions.single {
  grid-template-columns: 1fr;
}

.outline-result-action.half {
  width: 100%;
}
