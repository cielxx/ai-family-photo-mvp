<view class="page">
  <view class="eyebrow">二次调整</view>
  <view class="title">哪里还想再自然一点？</view>
  <view class="subtitle">选择问题标签，也可以补充一句你希望调整的方向。</view>

  <image class="image current-image" src="{{task.resultImageUrl}}" mode="aspectFill" />

  <view class="section-title">问题标签</view>
  <view class="pill-row">
    <block wx:for="{{issueOptions}}" wx:key="name">
      <view class="pill {{item.active ? 'active' : ''}}" data-tag="{{item.name}}" bindtap="toggleIssue">{{item.name}}</view>
    </block>
  </view>

  <view class="section-title">补充调整说明</view>
  <textarea class="textarea" maxlength="160" placeholder="例如：希望肤色更自然，背景不要太亮" value="{{adjustmentRequirement}}" bindinput="onRequirementInput"></textarea>

  <view class="spacer"></view>
  <button class="primary-button" disabled="{{!canSubmit}}" bindtap="submitAdjustment">提交调整</button>
</view>
