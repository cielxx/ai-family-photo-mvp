.upload-card {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.upload-preview {
  height: 430rpx;
}

.empty-upload {
  align-items: center;
  background: #f3eee5;
  border: 1rpx dashed #c9bfb3;
  border-radius: 14rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  height: 360rpx;
  justify-content: center;
  padding: 40rpx;
  text-align: center;
}

.empty-title {
  color: #2d3b46;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 14rpx;
}

.button-row {
  display: flex;
  gap: 16rpx;
}

.half-button {
  flex: 1;
}

.auth-row {
  align-items: flex-start;
  display: flex;
  gap: 16rpx;
  margin: 34rpx 0 28rpx;
}

.checkbox {
  border: 3rpx solid #b9afa3;
  border-radius: 8rpx;
  box-sizing: border-box;
  flex-shrink: 0;
  height: 36rpx;
  margin-top: 4rpx;
  width: 36rpx;
}

.checkbox.checked {
  background: #5b9a96;
  border-color: #5b9a96;
}

.auth-text {
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.45;
}
