<view class="page">
  <view class="eyebrow">{{service.shortName}}</view>
  <view class="title">{{service.name}}</view>
  <view class="subtitle">{{service.description}}</view>

  <view class="section-title">上传照片</view>
  <view class="card upload-card">
    <image wx:if="{{imageUrl}}" class="image upload-preview" src="{{imageUrl}}" mode="aspectFill" />
    <view wx:else class="empty-upload">
      <view class="empty-title">还没有选择照片</view>
      <view class="muted">可以从相册选择，也可以先用示例照片体验流程。</view>
    </view>
    <view class="button-row">
      <button class="secondary-button half-button" bindtap="chooseImage">选择照片</button>
      <button class="ghost-button half-button" bindtap="useSample">示例照片</button>
    </view>
  </view>

  <view class="section-title">处理重点</view>
  <view class="pill-row">
    <block wx:for="{{optionTags}}" wx:key="name">
      <view class="pill {{item.active ? 'active' : ''}}" data-tag="{{item.name}}" bindtap="toggleTag">{{item.name}}</view>
    </block>
  </view>

  <view class="section-title">补充说明</view>
  <textarea class="textarea" maxlength="160" placeholder="例如：希望保留年代感，不要磨皮过度" value="{{customRequirement}}" bindinput="onRequirementInput"></textarea>

  <view class="auth-row" bindtap="toggleAuthorization">
    <view class="checkbox {{authorizationConfirmed ? 'checked' : ''}}"></view>
    <view class="auth-text">我确认已获得照片中人物的使用授权</view>
  </view>

  <button class="primary-button" disabled="{{!canSubmit}}" bindtap="submitTask">开始处理照片</button>
</view>
