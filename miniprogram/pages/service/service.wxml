<view class="page">
  <view class="eyebrow">选择服务</view>
  <view class="title">你想先处理哪一类照片？</view>
  <view class="subtitle">第一版先用本地 mock 结果跑通流程，适合验证小程序体验。</view>

  <view class="stack">
    <block wx:for="{{services}}" wx:key="id">
      <view class="card service-card" data-id="{{item.id}}" bindtap="selectService">
        <view>
          <view class="service-name">{{item.name}}</view>
          <view class="service-desc">{{item.description}}</view>
        </view>
        <view class="service-action">选择</view>
      </view>
    </block>
  </view>
</view>
